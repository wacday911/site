---
import Base from '../layouts/Base.astro';
import { SITE } from '../data/site';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);
---

<Base title="Search — {SITE.name}" description="Search articles">
  <slot name="head">
    <script>
      import Fuse from 'fuse.js';
      const posts = JSON.parse(document.getElementById('search-data')?.textContent || '[]');
      const fuse = new Fuse(posts, {
        keys: ['title', 'description', 'tags', 'category'],
        threshold: 0.4,
      });
      const input = document.getElementById('search-input');
      const results = document.getElementById('search-results');
      input?.addEventListener('input', () => {
        const query = input.value.trim();
        if (!query) {
          results.innerHTML = '<p class="text-zinc-400 text-center py-10">Type something to search...</p>';
          return;
        }
        const matches = fuse.search(query).slice(0, 20);
        if (!matches.length) {
          results.innerHTML = '<p class="text-zinc-400 text-center py-10">No results found.</p>';
          return;
        }
        results.innerHTML = matches.map(({ item }) => `
          <a href="/${item.id}/" class="block border border-zinc-200 bg-white rounded-xl p-4 hover:shadow-md transition">
            <div class="text-xs text-zinc-400 mb-1">${item.category}</div>
            <h3 class="font-semibold">${item.title}</h3>
            <p class="text-sm text-zinc-500 mt-1">${item.description}</p>
          </a>
        `).join('');
      });
    </script>
    <script id="search-data" type="application/json" set:html={JSON.stringify(posts.map(p => ({ id: p.id, title: p.data.title, description: p.data.description, tags: p.data.tags, category: p.data.category })))} />
  </slot>

  <section class="mx-auto max-w-3xl px-4 py-12">
    <h1 class="mb-6 text-3xl font-bold">🔍 Search</h1>
    <input
      id="search-input"
      type="search"
      placeholder="Search articles..."
      class="mb-8 w-full rounded-xl border border-zinc-300 px-4 py-3 text-lg focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
      autofocus
    />
    <div id="search-results">
      <p class="text-center text-zinc-400">Type something to search...</p>
    </div>
  </section>
</Base>
