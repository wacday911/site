---
import Base from '../layouts/Base.astro';
import BlogCard from '../components/BlogCard.astro';
import { SITE } from '../data/site';
import { getCollection } from 'astro:content';
import { WebSiteSchema } from '../utils/schema';

const posts = await getCollection('blog', ({ data }) => !data.draft);
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const featured = posts.filter((p) => p.data.featured).slice(0, 3);
const latest = posts.slice(0, 9);
---

<Base>
  <slot name="head">
    <script type="application/ld+json" set:html={JSON.stringify([WebSiteSchema()])} />
  </slot>

  <section class="mx-auto max-w-5xl px-4 py-12">
    <div class="mb-10 text-center">
      <h1 class="text-4xl font-bold tracking-tight md:text-5xl">{SITE.name}</h1>
      <p class="mt-3 text-lg text-zinc-500">{SITE.tagline}</p>
    </div>

    {featured.length > 0 && (
      <div class="mb-12">
        <h2 class="mb-4 text-xl font-bold">🔥 Featured</h2>
        <div class="grid gap-4 md:grid-cols-3">
          {featured.map((post) => <BlogCard post={post} />)}
        </div>
      </div>
    )}

    <div>
      <h2 class="mb-4 text-xl font-bold">📝 Latest Posts</h2>
      <div class="grid gap-4 md:grid-cols-3">
        {latest.map((post) => <BlogCard post={post} />)}
      </div>
    </div>

    {posts.length === 0 && (
      <p class="py-20 text-center text-zinc-400">No posts yet. Check back soon!</p>
    )}
  </section>
</Base>
