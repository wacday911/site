---
import type { CollectionEntry } from 'astro:content';
import { formatDateShort, isRecent } from '../utils/dates';
import { SITE } from '../data/site';

export interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { id, data } = post;
const cat = SITE.categories.find((c) => c.slug === data.category);
---

<article class="group overflow-hidden rounded-xl border border-zinc-200 bg-white shadow-sm transition hover:shadow-md">
  <a href={`/${id}/`} class="block p-5">
    <div class="mb-3 flex items-center gap-2 text-xs text-zinc-400">
      <span class="rounded-full bg-zinc-100 px-2.5 py-0.5 font-medium text-zinc-600">
        {cat?.emoji} {cat?.label || data.category}
      </span>
      <time datetime={data.pubDate.toISOString()}>{formatDateShort(data.pubDate)}</time>
      {isRecent(data.pubDate) && (
        <span class="rounded-full bg-red-100 px-2 py-0.5 font-medium text-red-600">New</span>
      )}
    </div>
    <h2 class="text-lg font-semibold leading-snug group-hover:text-primary transition">
      {data.title}
    </h2>
    <p class="mt-2 line-clamp-2 text-sm text-zinc-500">{data.description}</p>
    <div class="mt-3 flex flex-wrap gap-1.5">
      {data.tags.slice(0, 3).map((tag) => (
        <span class="rounded bg-zinc-100 px-2 py-0.5 text-xs text-zinc-500">#{tag}</span>
      ))}
    </div>
  </a>
</article>
