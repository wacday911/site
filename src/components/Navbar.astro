---
import { SITE } from '../data/site';
---

<nav class="sticky top-0 z-50 border-b border-zinc-200 bg-white/80 backdrop-blur-md">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
    <a href="/" class="text-xl font-bold tracking-tight hover:text-primary transition">
      {SITE.name}
    </a>
    <div class="flex items-center gap-1">
      {SITE.categories.map((cat) => (
        <a
          href={`/categories/${cat.slug}/`}
          class="hidden rounded-lg px-3 py-1.5 text-sm font-medium text-zinc-600 hover:bg-zinc-100 hover:text-zinc-900 transition sm:inline-block"
        >
          {cat.emoji} {cat.label}
        </a>
      ))}
      <a href="/search/" class="ml-2 rounded-lg p-2 text-zinc-500 hover:bg-zinc-100 hover:text-zinc-700 transition" aria-label="Search">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
        </svg>
      </a>
    </div>
  </div>
</nav>
