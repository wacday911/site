---
import { SITE } from '../data/site';
---

<footer class="mt-16 border-t border-zinc-200 bg-white">
  <div class="mx-auto max-w-5xl px-4 py-10">
    <div class="grid gap-8 md:grid-cols-3">
      <div>
        <h3 class="mb-3 text-lg font-bold">{SITE.name}</h3>
        <p class="text-sm text-zinc-500">{SITE.description}</p>
      </div>
      <div>
        <h4 class="mb-3 font-semibold">Categories</h4>
        <ul class="space-y-1.5 text-sm text-zinc-500">
          {SITE.categories.map((cat) => (
            <li><a href={`/categories/${cat.slug}/`} class="hover:text-primary transition">{cat.emoji} {cat.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h4 class="mb-3 font-semibold">Quick Links</h4>
        <ul class="space-y-1.5 text-sm text-zinc-500">
          <li><a href="/about/" class="hover:text-primary transition">About</a></li>
          <li><a href="/search/" class="hover:text-primary transition">Search</a></li>
          <li><a href="/sitemap-index.xml" class="hover:text-primary transition">Sitemap</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-8 border-t border-zinc-100 pt-6 text-center text-xs text-zinc-400">
      <p>© {new Date().getFullYear()} {SITE.name}. Some links on this site are Amazon affiliate links. We may earn a commission at no extra cost to you.</p>
    </div>
  </div>
</footer>
