---
import Base from './Base.astro';
import type { CollectionEntry } from 'astro:content';
import { SITE } from '../data/site';
import { AMAZON } from '../data/affiliates';
import { BlogPostSchema, BreadcrumbSchema, WebSiteSchema } from '../utils/schema';
import { formatDate } from '../utils/dates';
import ShareButtons from '../components/ShareButtons.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import Icon from '../components/Icon.astro';

export interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { id, data } = post;
const url = `${SITE.url}/${id}/`;
const schemas = [WebSiteSchema(), BreadcrumbSchema([
  { name: SITE.name, url: SITE.url },
  { name: data.category, url: `${SITE.url}/categories/${data.category}/` },
  { name: data.title, url },
]), BlogPostSchema(post)];

const articleMeta = {
  publishedTime: data.pubDate.toISOString(),
  modifiedTime: data.updatedDate?.toISOString() || data.pubDate.toISOString(),
  tags: data.tags,
  section: data.category,
};
---

<Base title={data.title} description={data.description} image={data.image} ogType="article" articleMeta={articleMeta}>
  <slot name="head">
    <script type="application/ld+json" set:html={JSON.stringify(schemas)} />
  </slot>

    <article class="mx-auto max-w-3xl px-4 py-8">
      <header class="mb-8">
        <div class="mb-4 flex flex-wrap items-center gap-2 text-sm text-zinc-500">
          <a href={`/categories/${data.category}/`} class="rounded-full bg-primary/10 px-3 py-1 text-primary hover:bg-primary hover:text-white transition">
            {data.category}
          </a>
          <time datetime={data.pubDate.toISOString()}>{formatDate(data.pubDate)}</time>
          {data.updatedDate && (
            <span class="italic">(Updated {formatDate(data.updatedDate)})</span>
          )}
        </div>
        <h1 class="text-3xl font-bold tracking-tight md:text-4xl">{data.title}</h1>
        <p class="mt-2 text-lg text-zinc-600">{data.description}</p>
        <ShareButtons title={data.title} url={url} />
        {data.image && (
          <img
            src={data.image}
            alt={data.title}
            class="mt-6 w-full rounded-xl object-cover shadow-sm"
            width="1200"
            height="630"
            loading="eager"
          />
        )}
      </header>

    <div class="prose prose-zinc max-w-none prose-a:text-primary prose-img:rounded-lg">
      <slot />
    </div>

    {data.amazonAsin && (
      <div class="mt-8 rounded-xl border border-zinc-200 bg-white p-6 text-center shadow-sm">
        <p class="mb-3 inline-flex items-center gap-1.5 text-sm text-zinc-500">
          <Icon name="package" class="h-4 w-4" /> Check price on Amazon
        </p>
        <a
          href={`https://www.amazon.in/dp/${data.amazonAsin}?tag=${AMAZON.tag}`}
          target="_blank"
          rel="noopener sponsored"
          class="inline-block rounded-lg bg-accent px-6 py-3 font-semibold text-white hover:bg-amber-500 transition"
        >
          View on Amazon.in →
        </a>
      </div>
    )}

    <hr class="my-10" />

    <RelatedPosts current={post} />
  </article>
</Base>
